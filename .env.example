# Copy this file to .env and fill in your values.
# Docker Compose will automatically load .env from the project root.
#
# Tip: `make setup` generates config.yaml and .env interactively — including the
# CLI/subscription login flows — instead of editing this by hand.

# --- API keys (required: at least one) ---
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=

# --- Subscription tokens (optional; for the claude-code provider) ---
CLAUDE_CODE_OAUTH_TOKEN=

# --- Pipeline ---
# The product direction passed to the PM agent.
BUYCOTT_DIRECTION=Build a sample web application

# --- Ports ---
BUYCOTT_API_PORT=8080
BUYCOTT_DASHBOARD_PORT=8000

# --- Artifacts ---
# Host path where /artifacts is bind-mounted. Defaults to ./artifacts.
ARTIFACTS_PATH=./artifacts

# --- Image ---
# Override to use a pre-built image instead of building locally.
# BUYCOTT_IMAGE=myregistry/buycott:v1.2.3
